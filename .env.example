# Core secrets (required in production)
SECRET_KEY=change-me
JWT_SECRET_KEY=change-me-too

# Database — Railway MySQL auto-injects MYSQL_URL when linked to your service.
# Set DATABASE_URL=${{MySQL.MYSQL_URL}} in Railway, or rely on MYSQL_URL directly.
DATABASE_URL=mysql+pymysql://root:root123@localhost:3306/ai_exam_generator
MYSQL_URL=

# Individual DB vars (local dev fallback)
DB_USER=root
DB_PASSWORD=root123
DB_HOST=localhost
DB_PORT=3306
DB_NAME=ai_exam_generator

# AI features (required for exam/quiz generation and tutor chat)
AI_API_KEY=your-openai-api-key
AI_API_URL=https://api.openai.com/v1/chat/completions
AI_MODEL=gpt-4o-mini
